{
  "name": "kolbacoffproject-main",
  "version": "1.0.0",
  "description": "",
  "main": "script.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "npx live-server . --port=5500 --open=./index.html",
    "build": "mkdir -p dist && npx esbuild script.js --bundle --outfile=dist/script.js --minify",
    "copy-static": "cp index.html dist/ && cp booking.html dist/ && cp style.css dist/ && cp supabase.js dist/ && cp -r images dist/ && cp -r docs dist/",
    "predeploy": "npm run build && npm run copy-static",
    "deploy": "gh-pages -d dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "esbuild": "^0.19.4",
    "gh-pages": "^5.0.0",
    "live-server": "^1.2.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.32.0"
  }
}
